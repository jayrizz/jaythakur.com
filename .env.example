# Environment Variables for jaythakur.com

# Development
NODE_ENV=development
PORT=3001

# Service URLs (for local development)
OPENCLAW_URL=http://localhost:3000
QUANT_DASHBOARD_URL=http://localhost:5173
AOC_DASHBOARD_URL=http://localhost:18800

# API Keys (if needed)
# Add your API keys here for external services
# EXAMPLE_API_KEY=your_key_here

# Database (if added later)
# DATABASE_URL=your_database_url

# Security (for production)
# SECRET_KEY=your_secret_key
# NEXTAUTH_SECRET=your_auth_secret