{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/magazines/:path*",
      "destination": "/magazines/:path*"
    },
    {
      "source": "/family/:path*",
      "destination": "/family/:path*"
    },
    {
      "source": "/family/orlando2026",
      "destination": "/family/orlando2026.html"
    },
    {
      "source": "/family/orlando2026/",
      "destination": "/family/index.html"
    }
  ]
}
